# Tilāwah — environment variables. Copy to .env.local and fill real values.
# .env.local is gitignored (.env*.local). NEVER commit real secrets.

# --- Supabase (DB / auth / family-scope) ---
# Client-safe (publishable / anon). Safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# SERVER-ONLY. Bypasses Row-Level Security — never prefix NEXT_PUBLIC_, never bundle client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Groq Cloud (all AI: tafsīr Q&A, etc.) ---
# SERVER-ONLY. Never bundle client-side.
GROQ_API_KEY=your-groq-key

# --- Google OAuth (also configured in Supabase → Auth → Providers → Google) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# --- Audio / data (optional) ---
# Per-āyah reciter audio base URL (e.g. everyayah). If unset, audio disabled.
AUDIO_CDN_BASE=
# Sacred-text JSON base. Defaults to /data (bundled assets) when unset.
DATA_CDN_BASE=

# --- Quran.Foundation API (SERVER-ONLY OAuth2 client-credentials) ---
QURAN_FOUNDATION_ENV=prelive
QURAN_FOUNDATION_CLIENT_ID=your-prelive-client-id
QURAN_FOUNDATION_CLIENT_SECRET=your-prelive-client-secret
QURAN_FOUNDATION_OAUTH_BASE=https://prelive-oauth2.quran.foundation
QURAN_FOUNDATION_PROD_CLIENT_ID=your-prod-client-id
QURAN_FOUNDATION_PROD_CLIENT_SECRET=your-prod-client-secret
QURAN_FOUNDATION_PROD_OAUTH_BASE=https://oauth2.quran.foundation

# --- ASR ---
# deepgram | webspeech — Qurʾān/mutūn ḥifẓ recitation transcription.
ASR_PROVIDER=deepgram

# --- Deepgram (SERVER-ONLY) — live Arabic transcription for memorize mode ---
DEEPGRAM_API_KEY=your-deepgram-key
